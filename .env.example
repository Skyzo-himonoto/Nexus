# Database (PostgreSQL - Neon/Supabase)
DATABASE_URL="postgresql://user:password@localhost:5432/nexus_pedia"

# Next Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-min-32-chars"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Email (Nodemailer) - untuk OTP
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-app-password"

# Pusher (Realtime)
PUSHER_APP_ID="your-pusher-app-id"
PUSHER_KEY="your-pusher-key"
PUSHER_SECRET="your-pusher-secret"
PUSHER_CLUSTER="ap1"

# Upstash Redis (Rate Limit)
UPSTASH_REDIS_URL="your-upstash-redis-url"
UPSTASH_REDIS_TOKEN="your-upstash-redis-token"

# Cloudflare R2 (Storage)
R2_ACCOUNT_ID="your-account-id"
R2_ACCESS_KEY_ID="your-access-key"
R2_SECRET_ACCESS_KEY="your-secret-key"
R2_BUCKET_NAME="nexus-pedia"

# Payment Providers (Daftar di Duitku/Midtrans/Tripay)
DUITKU_MERCHANT_CODE="DP98765"
DUITKU_API_KEY="your-duitku-api-key"
DUITKU_SANDBOX_MODE="true"

MIDTRANS_SERVER_KEY="SB-Mid-server-xxx"
MIDTRANS_CLIENT_KEY="SB-Mid-client-xxx"
MIDTRANS_SANDBOX_MODE="true"

TRIPAY_API_KEY="DEV-xxx"
TRIPAY_PRIVATE_KEY="priv-xxx"
TRIPAY_MERCHANT_CODE="T12345"
TRIPAY_SANDBOX_MODE="true"

XENDIT_SECRET_KEY="xendit-secret-key"
XENDIT_SANDBOX_MODE="true"

# Owner Telegram (Customer Service)
OWNER_TELEGRAM_USERNAME="nexuspedia_support"

# Webhook Secret (untuk signature)
WEBHOOK_SECRET="whsec_your-secret-key-min-32-chars"

# ENCRYPTION KEY (untuk API key)
ENCRYPTION_KEY="your-encryption-key-min-32-chars"

# Next.js
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_WS_URL="ws://localhost:3000"
